# Congress
# Comma-separated full names to track. Names must match the House disclosures index.
CONGRESS_MEMBERS=Nancy Pelosi

# How far back to look for trades, in days.
CONGRESS_DAYS_BACK=365

# ARK ETF ticker: ARKK | ARKW | ARKG | ARKQ | ARKF | ARKX
ARK_FUND=ARKK

# Number of top holdings per portfolio.
TOP_N=10

# Output directory for generated files.
OUTPUT_DIR=output

# Optional API keys
# OpenRouter is needed to parse Trump's image-based White House PTR PDFs.
# Keep real keys in .env only.
OPENROUTER_API_KEY=

# Optional: raises OpenFIGI rate limits for Soros CUSIP-to-ticker lookups.
OPENFIGI_API_KEY=

# Optional: currently unused fallback source for Trump.
QUIVERQUANT_API_KEY=

# Optional: OpenRouter model for Trump PTR parsing.
TRUMP_PTR_MODEL=google/gemini-2.0-flash-lite-001
